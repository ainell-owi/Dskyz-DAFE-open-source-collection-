// 🌐 MARKET CONTEXT & LIQUIDITY FUSION
// ═══════════════════════════════════════════════════════════════════════════════
//@function Builds a unified MarketContext object, gracefully blending real footprint data with OHLCV mathematical approximations.
//@param o Open
//@param h High
//@param l Low
//@param c Close
//@param v Volume
//@param fp Footprint object (can be na)
//@param avg_vol Rolling average volume (e.g. SMA 20)
//@param prev_poc_mid Previous bar's footprint POC mid (for shift detection)
//@param atr_val Current ATR
//@returns MarketContext object with highly accurate liquidity metrics
export get_market_context(float o, float h, float l, float c, float v, footprint fp, float avg_vol, float prev_poc_mid, float atr_val) =>
    MarketContext ctx = MarketContext.new(0.0, 0.0, 0.0, 0.5, 0.0, 0.5, 0.0, 0.0, false)
    bool fp_ok = not na(fp)
    ctx.fp_active := fp_ok
    // OHLCV Fallbacks
    float rng = h - l
    float f_buy = 0.0, float f_sell = 0.0, float f_delta = 0.0
    if rng > 0 and v > 0
        float bp = (c - l) / rng
        float bb = c > o ? 1.1 : c < o ? 0.9 : 1.0
        f_buy := v * bp * bb
        f_sell := v * (1.0 - bp) * (2.0 - bb)
        float tot = f_buy + f_sell
        f_buy := tot > 0 ? f_buy / tot * v : v / 2.0
        f_sell := tot > 0 ? f_sell / tot * v : v / 2.0
        f_delta := f_buy - f_sell
    // Fusion
    ctx.unified_buy   := fp_ok ? fp.buy_volume() : f_buy
    ctx.unified_sell  := fp_ok ? fp.sell_volume() : f_sell
    ctx.unified_delta := fp_ok ? fp.delta() : f_delta
    float t_vol = ctx.unified_buy + ctx.unified_sell
    ctx.unified_agg   := t_vol > 0 ? ctx.unified_buy / t_vol : 0.5
    ctx.spread_proxy := _calc_spread_proxy(h, l, 20)
    ctx.vol_quality  := avg_vol > 0 ? _clamp(v / avg_vol, 0.0, 3.0) / 3.0 : 0.5
    // Absorption fusion
    ctx.absorption := fp_ok ? 
         ((c > o and ctx.unified_delta < 0) or (c < o and ctx.unified_delta > 0) ? 1.0 :
         (math.abs(c - o) < rng * 0.3 and v > avg_vol) ? 0.7 : 0.0) :
         ((c > o and f_delta < 0) or (c < o and f_delta > 0) ? 1.0 : 0.0)        
    // POC Shift
    if fp_ok and not na(prev_poc_mid)
        volume_row pr = fp.poc()
        float cur_poc = (pr.up_price() + pr.down_price()) / 2.0
        ctx.fp_poc_shift := (cur_poc - prev_poc_mid) / math.max(atr_val, syminfo.mintick)       
    ctx
//@function Calculates liquidity dynamics specifically at a given structural level
//@param level StructureLevel object
//@param price Current price
//@param atr_val Current ATR (used for proximity tolerance)
//@param ctx MarketContext object generated by get_market_context()
//@param avg_spread Rolling average spread
//@returns LevelLiquidity object containing defense/attack probabilities
export calc_level_liquidity(StructureLevel level, float price, float atr_val, MarketContext ctx, float avg_spread) =>
    LevelLiquidity liq = _empty_liq()
    if not na(level.price) and not na(price) and atr_val > 0
        float dist = math.abs(price - level.price)
        if dist <= atr_val * 0.5
            liq.sample_count := level.touch_count + 1
            liq.delta_at_level := ctx.unified_delta
            liq.volume_quality := ctx.vol_quality
            liq.spread_quality := avg_spread > 0 ? _clamp(1.0 - ctx.spread_proxy / (avg_spread * 2.0), 0.0, 1.0) : 0.5
            liq.absorption_rate := ctx.absorption
            liq.aggressor_ratio := ctx.unified_agg          
            int lev_dir = level.level_type == "swing_low" or level.level_type == "val" or level.level_type == "siege_sup" ? 1 : -1
            liq.action_type := _classify_action(ctx.unified_delta, ctx.spread_proxy, ctx.vol_quality, ctx.absorption, lev_dir)           
            float hold = 0.5
            if liq.action_type == "defending"
                hold += 0.25
            else if liq.action_type == "absorbing"
                hold += 0.15
            else if liq.action_type == "attacking"
                hold -= 0.20
            else if liq.action_type == "abandoning"
                hold -= 0.30               
            hold += liq.spread_quality * 0.10 + liq.volume_quality * 0.10 + level.strength * 0.10
            hold -= (1.0 - _clamp(float(level.touch_count) / 5.0, 0.0, 1.0)) * 0.05
            if level.touch_count >= 3
                hold -= 0.10                
            liq.hold_probability := _clamp(hold, 0.05, 0.95)
            liq.break_probability := 1.0 - liq.hold_probability
    liq
