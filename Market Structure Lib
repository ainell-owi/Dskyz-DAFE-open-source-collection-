_clamp(float x, float lo, float hi) => math.max(lo, math.min(hi, x))
_sgn(float x) => x > 0 ? 1.0 : x < 0 ? -1.0 : 0.0
_siege_decay(int h) => h == 0 ? 1.0 : h == 1 ? 0.9 : h == 2 ? 0.75 : h == 3 ? 0.5 : 0.1
_empty_liq() => 
    LevelLiquidity.new(0.0, 0.0, 0.5, 0.5, 0.5, 0.5, 0.5, "neutral", 0)
_make_corr(string tf, int dir) => 
    SiegeCorridor.new(na, na, na, na, dir, 0.0, 0, 1.0, 0.0, 0.0, false, 0.0, 0.0, tf, false)
_make_tf(string tf) => 
    TimeframeStructure.new(tf, na, na, na, array.new<StructureLevel>(), _make_corr(tf, 1), _make_corr(tf, -1), 0.0, 0, false)
_calc_spread_proxy(float h, float l, int lb) =>
    float hl1 = h > 0 and l > 0 ? math.log(h/l) : 0.0
    float phl = nz(h[1]) > 0 and nz(l[1]) > 0 ? math.log(h[1]/l[1]) : 0.0
    float beta = nz(ta.sma(hl1*hl1 + phl*phl, lb), 0.0) / 2.0
    float tbh = math.max(h, nz(h[1], h)), float tbl = math.min(l, nz(l[1], l))
    float gamma = tbh > 0 and tbl > 0 ? math.log(tbh/tbl) : 0.0
    float gs = nz(ta.sma(gamma*gamma, lb), 0.0)
    float s2 = math.sqrt(2.0), float dn = 3.0 - 2.0 * s2
    float a = 0.0
    if beta > 0
        a := (s2 - 1.0) * math.sqrt(beta) / dn
        if gs > beta
            a := (s2 - 1.0) * (math.sqrt(math.max(gs, 0.0)) - math.sqrt(beta)) / dn
    math.max(0.0, 2.0 * (math.exp(_clamp(a, -5.0, 5.0)) - 1.0) / (1.0 + math.exp(_clamp(a, -5.0, 5.0))) * 100.0)
_classify_action(float d, float sp, float vq, float ab, int dir) =>
    float al = d * dir
    ab > 0.6 and vq > 0.4 ? "absorbing" : al > 0 and vq > 0.5 and sp < 0.15 ? "defending" : al < 0 and vq > 0.3 ? "attacking" : vq < 0.2 ? "abandoning" : "neutral"
