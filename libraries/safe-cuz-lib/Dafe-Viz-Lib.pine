// ║                         DATA STRUCTURES                                    ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// @type Theme — Core color palette for consistent cross-indicator styling
export type Theme
    color p         // Primary accent
    color s         // Secondary accent
    color a         // Alert / highlight
    color bull      // Bullish state
    color bear      // Bearish state
    color neu       // Neutral state
    color bg        // Background
    color txt_hi    // High-contrast text
    color txt_lo    // Low-contrast / dim text

// @type MetricAnalysis — Statistical fingerprint of a data series
export type MetricAnalysis
    string data_type    // "oscillator", "momentum", "price", "volume"
    string regime       // "squeeze", "volatile", "trend"
    float  volatility   // Coefficient of variation (0-100)
    float  norm_value   // Normalized to 0-100 range
    float  z_score      // Standard deviations from mean
    bool   is_extreme   // |z| > 2.0

// @type PlotConfig — Complete auto-generated plot specification
export type PlotConfig
    float  value
    string title
    color  c_core       // Primary plot color
    color  c_glow       // Transparency-adjusted glow
    int    width
    string style        // "line", "area", "columns", "histogram", "stepline", "circles"
    bool   show_zones
    float  z_hi         // Upper zone boundary
    float  z_lo         // Lower zone boundary

// @type CandleDiag — Candle structure diagnostics
export type CandleDiag
    float body_pct      // Body as % of total range
    float upper_wick    // Upper wick as % of range
    float lower_wick    // Lower wick as % of range
    bool  is_doji       // Body < 10% of range
    bool  is_hammer     // Lower wick > 2x body
    bool  is_shooter    // Upper wick > 2x body
    bool  is_marubozu   // Body > 85% of range
    string bias         // "bull", "bear", "neutral"

// ╔════════════════════════════════════════════════════════════════════════════╗
// ║                         THEME ENGINE                                       ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// @function get_theme — Returns a complete color palette by name
// @param name Theme identifier
// @returns Theme object with all 9 color slots populated
export get_theme(string name) =>
    Theme t = Theme.new()
    if name == "Neon"
        t.p := #FF00FF, t.s := #00FFFF, t.a := #FFFF00
        t.bull := #00FF99, t.bear := #FF3366, t.neu := #6E5884
        t.bg := #09000D, t.txt_hi := #FFFFFF, t.txt_lo := #B080B0
    else if name == "Cyber"
        t.p := #00E5FF, t.s := #2979FF, t.a := #76FF03
        t.bull := #00E676, t.bear := #FF1744, t.neu := #546E7A
        t.bg := #000a12, t.txt_hi := #E0FFFF, t.txt_lo := #406070
    else if name == "Matrix"
        t.p := #00FF41, t.s := #008F11, t.a := #CCFF00
        t.bull := #00FF41, t.bear := #FF3333, t.neu := #445544
        t.bg := #000500, t.txt_hi := #AAFFAA, t.txt_lo := #225522
    else if name == "Gold"
        t.p := #FFD700, t.s := #FFA500, t.a := #FFFFFF
        t.bull := #FDD835, t.bear := #FF5722, t.neu := #8D6E63
        t.bg := #12100b, t.txt_hi := #FFF8E1, t.txt_lo := #6D4C41
    else if name == "Ice"
        t.p := #00FFFF, t.s := #AAFFFF, t.a := #00DDDD
        t.bull := #88FFFF, t.bear := #FF6699, t.neu := #99CCCC
        t.bg := #0a1a1a, t.txt_hi := #E0FFFF, t.txt_lo := #407070
    else if name == "Blood"
        t.p := #FF3333, t.s := #FF8888, t.a := #DD0000
        t.bull := #00FF88, t.bear := #FF1144, t.neu := #CC6666
        t.bg := #1a0000, t.txt_hi := #FFCCCC, t.txt_lo := #884444
    else if name == "DAFE Signature"
        t.p := #2962FF, t.s := #00BCD4, t.a := #FF6D00
        t.bull := #00E676, t.bear := #FF1744, t.neu := #78909C
        t.bg := #0D1117, t.txt_hi := #E6EDF3, t.txt_lo := #8B949E
    else
        // Clean / Default
        t.p := #2962FF, t.s := #448AFF, t.a := #FF6D00
        t.bull := #00C853, t.bear := #D50000, t.neu := #9E9E9E
        t.bg := #FFFFFF, t.txt_hi := #212121, t.txt_lo := #757575
    t

// ╔════════════════════════════════════════════════════════════════════════════╗
// ║                    INTELLIGENT METRIC ANALYSIS                             ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// @function analyze — Statistically fingerprint any data series
// @param src Input series
// @param len Lookback window
// @returns MetricAnalysis with data_type, regime, volatility, z-score
export analyze(series float src, int len = 50) =>
    MetricAnalysis a = MetricAnalysis.new()
    float hi_val  = ta.highest(src, len)
    float lo_val  = ta.lowest(src, len)
    float avg     = ta.sma(src, len)
    float rng     = hi_val - lo_val
    float std     = ta.stdev(src, len)
    bool is_bounded  = hi_val <= 105 and lo_val >= -5
    bool is_centered = hi_val > 0 and lo_val < 0 and math.abs(avg) < (rng * 0.1)
    if is_bounded and not is_centered
        a.data_type := "oscillator"
    else if is_centered
        a.data_type := "momentum"
    else if src >= 0 and rng > avg
        a.data_type := "price"
    else
        a.data_type := "volume"
    float cv = avg != 0 ? (std / math.abs(avg)) * 100 : 0
    a.volatility := math.min(cv, 100)
    a.regime := cv < 5 ? "squeeze" : cv > 20 ? "volatile" : "trend"
    a.norm_value := rng != 0 ? (src - lo_val) / rng * 100 : 50
    a.z_score    := std > 0 ? (src - avg) / std : 0.0
    a.is_extreme := math.abs(a.z_score) > 2.0
    a

// ╔════════════════════════════════════════════════════════════════════════════╗
// ║                    AUTO-CONFIGURATION ENGINE                               ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// @function auto_config — Analyzes data and returns complete plot specification
// @param src Input series
// @param title Plot title
// @param t Theme object
// @returns PlotConfig with value, colors, width, style, zones
export auto_config(series float src, string title, Theme t) =>
    float vol_sma = ta.sma(src, 20)
    MetricAnalysis a = analyze(src)
    PlotConfig cfg = PlotConfig.new()
    cfg.title := title
    cfg.value := src
    color base_c = t.neu
    if a.data_type == "oscillator"
        base_c := a.norm_value < 50 ? color.from_gradient(a.norm_value, 0, 50, t.bear, t.neu) : color.from_gradient(a.norm_value, 50, 100, t.neu, t.bull)
    else if a.data_type == "momentum"
        base_c := src > 0 ? t.bull : t.bear
    else if a.data_type == "price"
        base_c := src > src[1] ? t.bull : t.bear
    else
        base_c := src > vol_sma ? t.p : t.s
    int opacity = a.regime == "squeeze" ? 90 : a.regime == "volatile" ? 40 : 70
    cfg.c_core := base_c
    cfg.c_glow := color.new(base_c, opacity)
    cfg.width := a.regime == "volatile" ? 3 : a.regime == "squeeze" ? 1 : 2
    if a.data_type == "oscillator"
        cfg.style := "line"
        cfg.show_zones := true
        cfg.z_hi := 70.0
        cfg.z_lo := 30.0
    else if a.data_type == "momentum"
        cfg.style := "area"
        cfg.show_zones := false
        cfg.z_hi := na
        cfg.z_lo := na
    else if a.data_type == "volume"
        cfg.style := "columns"
        cfg.show_zones := false
        cfg.z_hi := na
        cfg.z_lo := na
    else
        cfg.style := "line"
        cfg.show_zones := false
        cfg.z_hi := na
        cfg.z_lo := na
    cfg

// ╔════════════════════════════════════════════════════════════════════════════╗
// ║                    COLOR ENGINE — GRADIENTS & INTERPOLATION                ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// @function gradient_color — Linear interpolation between two colors
// @param value Input (0-100 range)
// @param c1 Start color (at 0)
// @param c2 End color (at 100)
// @returns Interpolated color
export gradient_color(float value, color c1, color c2) =>
    float n = math.max(0.0, math.min(100.0, value)) / 100.0
    color.rgb(
     int(color.r(c1) + (color.r(c2) - color.r(c1)) * n),
     int(color.g(c1) + (color.g(c2) - color.g(c1)) * n),
     int(color.b(c1) + (color.b(c2) - color.b(c1)) * n))

// @function gradient_3 — Three-point gradient (low → mid → high)
// @param value Current value
// @param lo Lower bound
// @param mid Midpoint
// @param hi Upper bound
// @param c1 Color at lo
// @param c2 Color at mid
// @param c3 Color at hi
// @returns Interpolated color
export gradient_3(float value, float lo, float mid, float hi, color c1, color c2, color c3) =>
    value <= mid ? color.from_gradient(value, lo, mid, c1, c2) : color.from_gradient(value, mid, hi, c2, c3)

// @function heatmap_color — Theme-aware heatmap from value relative to a max
// @param val Current value
// @param lookback_max Maximum for normalization
// @param t Theme object
// @returns Heatmap color (bg → secondary → primary)
export heatmap_color(float val, float lookback_max, Theme t) =>
    float n = math.max(0.0, math.min(1.0, lookback_max != 0 ? val / lookback_max : 0.5))
    gradient_3(n, 0.0, 0.5, 1.0, t.bg, t.s, t.p)

// @function state_color — Get color for named states
// @param state State string ("healthy", "fragile", "failed", "bull", "bear", etc.)
// @param t Theme object
// @returns Appropriate color
export state_color(string state, Theme t) =>
    state == "healthy" or state == "bull" or state == "long" or state == "bullish" ? t.bull :
     state == "failed" or state == "bear" or state == "short" or state == "bearish" ? t.bear :
     state == "fragile" or state == "warning" or state == "caution" ? t.a :
     state == "extreme" or state == "alert" ? t.a :
     state == "squeeze" or state == "compression" ? t.s :
     state == "active" or state == "strong" ? t.p :
     t.neu

// ╔════════════════════════════════════════════════════════════════════════════╗
// ║  FIX: adaptive_alpha — ALL-FLOAT INTERNALS                                 ║
// ║  Pine v5 export resolution fails when int/float arithmetic is mixed        ║
// ║  internally and the function is called cross-script. Using float           ║
// ║  throughout and casting to int only at the final return fixes this.         ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// @function adaptive_alpha — Calculate transparency based on confidence/strength
// @param confidence Value 0.0-1.0 (higher = more opaque)
// @param base_alpha Minimum transparency (0-100)
// @returns Transparency value for color.new()
export adaptive_alpha(float confidence, float base_alpha = 80.0) =>
    float clamped  = math.max(0.0, math.min(1.0, confidence))
    float range_a  = base_alpha - 5.0
    float result   = base_alpha - clamped * range_a
    int(math.max(5.0, math.min(95.0, result)))

// @function get_neon — Returns core + glow color pair for neon effects
// @param base_color Base color
// @param glow_alpha Glow transparency (0-100)
// @returns [core_color, glow_color]
export get_neon(color base_color, int glow_alpha = 70) =>
    [base_color, color.new(base_color, glow_alpha)]

// @function get_intensity — Modulate color opacity by a ratio
// @param base_color Base color
// @param ratio Intensity ratio (higher = brighter, 100 = base)
// @returns Color with adjusted transparency
export get_intensity(color base_color, float ratio) =>
    int alpha = int(math.max(5, math.min(95, 100 - ratio)))
    color.new(base_color, alpha)

// ╔════════════════════════════════════════════════════════════════════════════╗
// ║                    CANDLE DIAGNOSTICS                                      ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// @function diagnose_candle — Full structural analysis of a candle
// @param idx Bar offset (0 = current)
// @returns CandleDiag with body/wick percentages and pattern flags
export diagnose_candle(int idx = 0) =>
    CandleDiag d = CandleDiag.new()
    float o = open[idx]
    float h = high[idx]
    float l = low[idx]
    float c = close[idx]
    float rng = h - l
    if rng > 0
        float body = math.abs(c - o)
        float body_top = math.max(c, o)
        float body_bot = math.min(c, o)
        d.body_pct    := body / rng * 100
        d.upper_wick  := (h - body_top) / rng * 100
        d.lower_wick  := (body_bot - l) / rng * 100
        d.is_doji     := d.body_pct < 10
        d.is_hammer   := d.lower_wick > d.body_pct * 2 and d.upper_wick < d.body_pct
        d.is_shooter  := d.upper_wick > d.body_pct * 2 and d.lower_wick < d.body_pct
        d.is_marubozu := d.body_pct > 85
        d.bias := c > o ? "bull" : c < o ? "bear" : "neutral"
    else
        d.body_pct := 0.0
        d.upper_wick := 0.0
        d.lower_wick := 0.0
        d.is_doji := true
        d.bias := "neutral"
    d

// @function candle_color — Intelligent candle coloring based on diagnostics
// @param t Theme object
// @param health_pct Health score 0-100
// @param direction 1=bull, -1=bear, 0=neutral
// @returns [body_color, wick_color, border_color]
export candle_color(Theme t, float health_pct, int direction) =>
    CandleDiag d = diagnose_candle(0)
    float alpha_f = math.max(5.0, math.min(95.0, 60.0 - math.max(0.0, math.min(1.0, health_pct / 100.0)) * 55.0))
    int alpha = int(alpha_f)
    color body_c = na
    if d.is_doji
        body_c := t.neu
    else if d.is_marubozu
        body_c := d.bias == "bull" ? t.bull : t.bear
    else if d.is_hammer and direction >= 0
        body_c := t.bull
    else if d.is_shooter and direction <= 0
        body_c := t.bear
    else
        body_c := d.bias == "bull" ? color.new(t.bull, alpha) : color.new(t.bear, alpha)
    color wick_c = color.new(body_c, math.min(95, alpha + 20))
    color border_c = color.new(body_c, math.max(0, alpha - 10))
    [body_c, wick_c, border_c]

// ╔════════════════════════════════════════════════════════════════════════════╗
// ║                    VALUE PROCESSING                                        ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// @function normalize — Scale any value to 0-100 range
// @param value Input value
// @param lo Expected minimum
// @param hi Expected maximum
// @returns Normalized value clamped to 0-100
export normalize(float value, float lo, float hi) =>
    float rng = hi - lo
    rng != 0 ? math.max(0.0, math.min(100.0, (value - lo) / rng * 100.0)) : 50.0

// @function normalize_oscillator — Center-referenced normalization (-100 to +100)
// @param value Input value
// @param hi Upper reference bound
// @param lo Lower reference bound
// @returns Normalized value centered on 0
export normalize_oscillator(float value, float hi, float lo) =>
    float mid = (hi + lo) / 2
    float rng = hi - lo
    rng != 0 ? ((value - mid) / (rng / 2)) * 100 : 0.0

// @function calculate_volume_ratio — Volume relative to average
// @param current_vol Current bar volume
// @param avg_vol Average volume
// @returns Ratio as percentage (100 = average)
export calculate_volume_ratio(float current_vol, float avg_vol) =>
    avg_vol > 0 ? (current_vol / avg_vol) * 100 : 100.0

// @function get_volume_color — Color by volume strength
// @param ratio Volume ratio (100 = average)
// @param t Theme object
// @returns Gradient color (secondary at low → primary at high)
export get_volume_color(float ratio, Theme t) =>
    gradient_color(math.min(ratio, 200) / 2, t.s, t.p)

// @function get_background_color — State-based background with intensity
// @param state_name State identifier
// @param intensity Opacity strength (0.0-1.0)
// @param t Theme object
// @returns Background color with appropriate transparency
export get_background_color(string state_name, float intensity, Theme t) =>
    color base = state_color(state_name, t)
    float transp = 100.0 - intensity * 15.0
    color.new(base, int(math.max(80.0, transp)))

// ╔════════════════════════════════════════════════════════════════════════════╗
// ║                    UI & HUD TOOLKIT                                        ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// @function smart_text — Auto-contrast text color for any background
// @param bg Background color
// @returns Black or white for optimal readability
export smart_text(color bg) =>
    float luminance = 0.299 * color.r(bg) + 0.587 * color.g(bg) + 0.114 * color.b(bg)
    luminance > 160 ? #000000 : #FFFFFF

// @function get_plot_style — Convert string to plot.style constant
// @param s Style name
// @returns plot.style_* constant
export get_plot_style(string s) =>
    s == "histogram" ? plot.style_histogram :
     s == "area" ? plot.style_area :
     s == "columns" ? plot.style_columns :
     s == "stepline" ? plot.style_stepline :
     s == "circles" ? plot.style_circles :
     plot.style_line

// @function draw_bar — ASCII progress bar
// @param pct Percentage (0-100)
// @param len Character length
// @returns Bar string like "████░░░░"
export draw_bar(float pct, int len = 10) =>
    int filled = math.round(math.max(0.0, math.min(100.0, pct)) / 100 * len)
    string bar = ""
    if filled > 0
        for i = 1 to filled
            bar += "█"
    if filled < len
        for i = 1 to (len - filled)
            bar += "░"
    bar

// @function draw_bar_pointed — Progress bar with pointer showing current position
// @param pct Percentage (0-100)
// @param len Character length
// @returns Bar string like "███▸░░░░"
export draw_bar_pointed(float pct, int len = 10) =>
    int pos = math.round(math.max(0.0, math.min(100.0, pct)) / 100 * (len - 1))
    string bar = ""
    for i = 0 to len - 1
        if i < pos
            bar += "█"
        else if i == pos
            bar += "▸"
        else
            bar += "░"
    bar

// @function draw_stars — 5-star rating system
// @param s Score (0.0 to 1.0)
// @returns Star string
export draw_stars(float s) =>
    s > 0.8 ? "★★★★★" : s > 0.6 ? "★★★★☆" : s > 0.4 ? "★★★☆☆" : s > 0.2 ? "★★☆☆☆" : "★☆☆☆☆"

// @function draw_trend — Direction arrow character
// @param val Positive, negative, or zero
// @returns Arrow or block character
export draw_trend(float val) =>
    val > 0 ? "▲" : val < 0 ? "▼" : "■"

// @function draw_trend_word — Direction as colored word
// @param val Positive, negative, or zero
// @returns "LONG", "SHORT", or "FLAT"
export draw_trend_word(float val) =>
    val > 0 ? "LONG" : val < 0 ? "SHORT" : "FLAT"

// @function draw_gauge — Horizontal gauge with zones
// @param value Current
