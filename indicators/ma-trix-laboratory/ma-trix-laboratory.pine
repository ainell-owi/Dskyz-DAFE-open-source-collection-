i_use_smoothing = input.bool(false, "🎛️ Enable Post-Smoothing", group=g_smoothing)
i_smooth_type = input.string("SuperSmoother", "Smoother Type (All MAs)", 
     options=["None", "SuperSmoother", "Ehlers 2-Pole", "Ehlers 3-Pole",
