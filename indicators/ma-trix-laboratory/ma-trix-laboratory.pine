i_alert_sell = input.bool(true, "🔔 Sell Signal", group=g_alerts, inline="alert")
i_alert_cross = input.bool(false, "🔔 Any Cross", group=g_alerts, inline="alert")
// ═══════════════════════════════════════════════════════════════════════════════
// CONSTANTS
// ═══════════════════════════════════════════════════════════════════════════════
var float PI = 3.14159265359
var float SQRT2 = 1.41421356237
// ═══════════════════════════════════════════════════════════════════════════════
// EFFECTIVE MODE LOGIC 
// ═══════════════════════════════════════════════════════════════════════════════
bool isTripleMode = i_mode == "Triple MA Cross" or i_mode == "Triple MA Aligned" or i_mode == "Triple MA Ribbon"
bool isDualMode = i_mode == "Dual MA Cross" or i_mode == "Dual MA Ribbon"
bool isSingleMode = i_mode == "Single MA"
bool use_ma2 = isSingleMode ? false : i_ma2_enable
bool use_ma3 = isTripleMode ? i_ma3_enable : false
string eff_signal_mode = i_signal_mode
if i_signal_mode == "Auto (Mode-Based)"
    if isSingleMode
        eff_signal_mode := "Price Cross MA1"
    else if i_mode == "Triple MA Cross"
        eff_signal_mode := "Triple MA Cross"
    else if i_mode == "Triple MA Aligned"
        eff_signal_mode := "Triple MA Aligned"
    else if i_mode == "Triple MA Ribbon"
        eff_signal_mode := "Triple MA Aligned"
    else  
        eff_signal_mode := "Dual MA Cross"
if (eff_signal_mode == "Triple MA Cross" or eff_signal_mode == "Triple MA Aligned" or eff_signal_mode == "Fast Cross Slow" or eff_signal_mode == "Sequential Cross" or eff_signal_mode == "Triple Confirm") and not use_ma3 
    eff_signal_mode := use_ma2 ? "Dual MA Cross" : "Price Cross MA1"
if eff_signal_mode == "Dual MA Cross" and not use_ma2
    eff_signal_mode := "Price Cross MA1"
string eff_ribbon_mode = (i_mode == "Dual MA Ribbon" or i_mode == "Triple MA Ribbon") ? i_ribbon_mode : "None"
// ═══════════════════════════════════════════════════════════════════════════════
// HELPER FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════
f_er(src, len) =>
    change_sum = math.sum(math.abs(src - src[1]), len)
    net