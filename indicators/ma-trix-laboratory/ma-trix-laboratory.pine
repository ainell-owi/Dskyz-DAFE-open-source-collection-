// ╚═════════════════════════════════════════════════════════════════════╝
// GROUPS
// ═══════════════════════════════════════════════════════════════════════
var g_mode     = "══════════════ 🎯 OPERATION MODE ══════════════"
var g_ma_core  = "══════════════ 📊 MOVING AVERAGES ══════════════"
var g_ma_advanced = "═══════════ ⚙️ MA ADVANCED PARAMETERS ═════════"
var g_smoothing = "═════════════ 🎛️ POST-SMOOTHING ══════════════"
var g_signals  = "══════════════ ⚡ SIGNALS & RIBBONS ══════════════"
var g_filters  = "══════════════ 🔬 SIGNAL FILTERS ══════════════"
var g_visual   = "══════════════ 🎨 VISUALIZATION ══════════════"
var g_perf     = "══════════════ 📊 PERFORMANCE TRACKING ═══════════"
var g_dash     = "══════════════ 📋 DASHBOARD ══════════════"
var g_alerts   = "══════════════ 🔔 ALERTS ══════════════"
// ═══════════════════════════════════════════════════════════════════════════════
// TOOLTIPS
// ═══════════════════════════════════════════════════════════════════════════════
string TT_MODE = "OPERATION MODE:\n\n• SINGLE MA: Only MA1 displayed\n• DUAL MA: MA1 + MA2 crossovers\n• TRIPLE MA: All 3 MAs for alignment strategies\n• RIBBON: Fills between MAs\n\n💡 Classic setups:\n  - Dual: 20/50 EMA\n  - Triple: 10/20/50 or 20/50/200"
string TT_MA_TYPE = "Select MA algorithm. 55+ options from basic (SMA/EMA) to advanced (KAMA/FRAMA) to DAFE proprietary.\n\n💡 Best all-rounders: EMA, Hull MA, KAMA"
string TT_MA_LEN = "Lookback period.\n\n• Fast: 5-20\n• Medium: 20-50\n• Slow: 50-200+\n\n💡 Common: 20, 50, 100, 200"
string TT_MA_SRC = "Price source for calculation.\n\n• close: Standard\n• hl2: Median\n• hlc3: Typical\n• ohlc4: Average"
string TT_SMOOTHER = "Post-process filter to reduce noise.\n\n• None: Raw MA\n• SuperSmoother: Ehlers DSP filter\n• Kalman: Optimal estimation\n• Phase-Zero: DAFE lag cancellation\n\n⚠️ Adds smoothing but slight lag"
string TT_SIGNAL_MODE = "How signals are generated:\n\n• PRICE CROSS MA1: Price crosses MA1\n• DUAL MA CROSS: MA1 crosses MA2\n• TRIPLE ALIGNED: All 3 MAs in order\n• TRIPLE MA CROSS: MA1 crosses MA2 with MA3 confirmation\n• FAST CROSS SLOW: MA1 crosses MA3 directly\n• SLOPE CHANGE: MA direction reversal"
string TT_RIBBON_MODE = "Ribbon visualization:\n\n• NONE: No fills\n• MA1-MA2: Fill between fast/medium\n• ALL RIBBONS: Fill all gaps\n• GRADIENT: Layered transparency"
string TT_FILTERS = "Combined signal filters:\n\n📦 VOLUME: Require above-average volume\n🌊 VOLATILITY: Filter by ATR/BB conditions\n💪 TREND: ADX strength requirement\n🚀 MOMENTUM: RSI/MACD confirmation\n⏰ TIME: Min bars between signals"
string TT_FILTER_VOLUME = "Require volume confirmation:\n\n• OFF: No volume filter\n• ABOVE AVG: Volume > SMA(20)\n• THRESHOLD: Volume > X% above avg\n• CLIMAX: Extremely high vol"
string TT_FILTER_VOL_MULT = "Volume must be this multiple above average.\n\n• 1.2 = 20% above avg\n• 1.5 = 50% above avg\n• 2.0 = 2x average"
string TT_FILTER_VOLATILITY = "Filter by volatility conditions:\n\n• ATR THRESHOLD: Require high/low ATR\n• BB SQUEEZE: Low volatility (breakout setup)\n• BB EXPANSION: High volatility (trending)"
string TT_FILTER_TREND = "Require trend strength (ADX):\n\n• STRONG TREND: ADX > threshold\n• WEAK TREND: ADX < threshold\n• DIRECTIONAL: DI+ vs DI- alignment"
string TT_FILTER_MOMENTUM = "Confirm with momentum indicators:\n\n• RSI: Must be in bull/bear zone\n• ROC: Direction confirmation\n• MACD: Line above/below signal\n• STOCHASTIC: Overbought/oversold zones"
string TT_FILTER_TIME = "Minimum bars between signals to prevent rapid whipsaws."
