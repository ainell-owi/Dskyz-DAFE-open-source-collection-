i_ma3_len = input.int(200, "Length", minval=1, maxval=500, group=g_ma_core, inline="ma3", tooltip=TT_MA_LEN)
i_ma3_src = input.source(close, "Source", group=g_ma_core, inline="ma3", tooltip=TT_MA_SRC)
i_ma3_offset = input.int(0, "Offset", minval=-50, maxval=50, group=g_ma_core, inline="ma3")
i_alma_offset = input.float(0.85, "ALMA Offset (All MAs)", minval=0.0, maxval=1.0, step=0.05, group=g_ma_advanced,
     tooltip="ALMA Gaussian offset. 0.85 = standard. Higher = more responsive.")
i_alma_sigma = input.float(6.0, "ALMA Sigma (All MAs)", minval=1.0, maxval=20.0, step=0.5, group=g_ma_advanced,
     tooltip="ALMA Gaussian sigma. 6 = standard. Higher = smoother.")
i_t3_factor = input.float(0.7, "T3 Volume Factor (All MAs)", minval=0.0, maxval=1.0, step=0.05, group=g_ma_advanced,
