              "DAFE Flux Reactor", "DAFE Tensor Flow", "DAFE Quantum Step",
              "DAFE Spectral Filter", "DAFE Gravity Well", "DAFE Hybrid Adaptive",
              "Parabolic SAR MA"], 
     group=g_ma_core, inline="ma2", tooltip=TT_MA_TYPE)
i_ma2_len = input.int(50, "Length", minval=1, maxval=500, group=g_ma_core, inline="ma2", tooltip=TT_MA_LEN)
i_ma2_src = input.source(close, "Source", group=g_ma_core, inline="ma2", tooltip=TT_MA_SRC)
i_ma2_offset = input.int(0, "Offset", minval=-50, maxval=50, group=g_ma_core, inline="ma2")
i_ma3_enable = input.bool(true, "📉 MA3 (Tertiary/Slow)", group=g_ma_core, inline="ma3_en")
i_ma3_type = input.string("SMA", "Type", 
     options=["SMA", "EMA", "WMA", "VWMA", "RMA (Wilder)", "SMMA", 
              "DEMA", "TEMA", "Hull MA", "ZLEMA", "ALMA", "T3 Tillson",
              "KAMA", "VIDYA", "FRAMA", "McGinley Dynamic", "Jurik (JMA)",
              "Ahrens MA", "REMA", "EVWMA", "Gaussian MA", "Sine-Weighted MA",
              "Triangular MA", "Linear Regression", "Median MA",
              "Geometric Mean MA", "Harmonic Mean MA", "Quadratic MA", "Cubic MA",
              "Ehlers Filter", "Butterworth MA", "Chebyshev MA", "Bessel MA",
              "SuperSmoother MA", "Laguerre MA", "Adaptive Laguerre",
              "Zero-Lag DEMA", "Zero-Lag TEMA", "Variable MA",
              "Volatility Adjusted MA", "Volume Zone MA", "Karobein MA", "Rex MA",
              "DAFE Flux Reactor", "DAFE Tensor Flow", "DAFE Quantum Step",
              "DAFE Spectral Filter", "DAFE Gravity Well", "DAFE Hybrid Adaptive",
