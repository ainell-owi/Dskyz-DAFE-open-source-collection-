              "Kalman Filter", "Laguerre Filter", "Adaptive Laguerre",
              "Hamming Window", "Hann Window", "Blackman Window",
              "Linear Regression", "Median Filter",
              "DAFE Phase-Zero", "DAFE Spectral Smooth", "DAFE Quantum Smooth"], 
     group=g_smoothing, tooltip=TT_SMOOTHER)
i_smooth_len = input.int(8, "Smoother Length", minval=2, maxval=50, group=g_smoothing, tooltip="Smoothing period. 8-12 recommended.")
i_signal_mode = input.string("Auto (Mode-Based)", "⚡ Signal Mode", 
     options=["Auto (Mode-Based)", "Price Cross MA1", "Dual MA Cross", "Triple MA Aligned", "Triple MA Cross", 
              "Fast Cross Slow", "Sequential Cross", "Slope Change", "Price + Slope", "Triple Confirm"],
     group=g_signals, tooltip=TT_SIGNAL_MODE)
i_signal_confirm_bars = input.int(1, "Confirmation Bars", minval=1, maxval=10, group=g_signals, 
     tooltip="Bars condition must persist. 1-2 recommended.")
i_triple_alignment_strict = input.bool(true, "Strict Triple Alignment", group=g_signals,
     tooltip="Require MA1 > MA2 > MA3 exact order (if off, just same direction)")
i_ribbon_mode = input.string("All Ribbons", "🎀 Ribbon Mode", 
     options=["None", "MA1-MA2 Only", "MA2-MA3 Only", "MA1-MA3 Span", "All Ribbons", "Gradient Stack"],
     group=g_signals, tooltip=TT_RIBBON_MODE)
i_ribbon_transparency = input.int(85, "Ribbon Transparency", minval=50, maxval=95, group=g_signals)
i_enable_filters = input.bool(false, "🔬 Enable Signal Filters", group=g_filters, tooltip=TT_FILTERS)
i_vol_enable = input.bool(false, "📦 Volume Filter", group=g_filters, inline="vol", tooltip=TT_FILTER_VOLUME)
i_vol_mode = input.string("Above Threshold", "", 
     options=["Above Average", "Above Threshold", "Climax Detection", "Dry Up Detection"],
     group=g_filters, inline="vol")
i_vol_mult = input.float(1.2, "Multiplier", minval=1.0, maxval=5.0, step=0.1, group=g_filters, inline="vol2", tooltip=TT_FILTER_VOL_MULT)
i_vol_len = input.int(20, "Length", minval=5, maxval=100, group=g_filters, inline="vol2")
i_volatility_enable = input.bool(false, "🌊 Volatility Filter", group=g_filters, inline="volty", tooltip=TT_FILTER_VOLATILITY)
i_volatility_mode = input.string("BB Expansion", "", 
     options=["ATR Above Threshold", "ATR Below Threshold", "BB Squeeze", "BB Expansion", "Historical Percentile High", "Historical Percentile Low"],
     group=g_filters, inline="volty")
i_volatility_atr_len = input.int(14, "ATR Len", minval=5, maxval=50, group=g_filters, inline="volty2")
i_volatility_atr_mult = input.float(1.0, "Threshold", minval=0.1, maxval=3.0, step=0.1, group=g_filters, inline="volty2")
i_trend_enable = input.bool(false, "💪 Trend Filter (ADX)", group=g_filters, inline="trend", tooltip=TT_FILTER_TREND)
i_trend_mode = input.string("Require Strong Trend", "", 
     options=["Require Strong Trend", "Require Weak Trend", "Directional Alignment"],
     group=g_filters, inline="trend")
i_trend_adx_len = input.int(14, "ADX Len", minval=5, maxval=50, group=g_filters, inline="trend2")
i_trend_adx_thresh = input.int(25, "Threshold", minval=10, maxval=50, group=g_filters, inline="trend2")
i_mom_enable = input.bool(false, "🚀 Momentum Filter", group=g_filters, inline="mom", tooltip=TT_FILTER_MOMENTUM)
i_mom_mode = input.string("RSI Confirmation", "", 
     options=["RSI Confirmation", "ROC Direction", "MACD Alignment", "Stochastic Zone"],
     group=g_filters, inline="mom")
i_mom_rsi_len = input.int(14, "RSI Len", minval=5, maxval=50, group=g_filters, inline="mom2")
i_mom_rsi_bull = input.int(50, "Bull >", minval=30, maxval=70, group=g_filters, inline="mom2")
i_mom_rsi_bear = input.int(50, "Bear <", minval=30, maxval=70, group=g_filters, inline="mom2")
i_mom_roc_len = input.int(10, "ROC Length", minval=3, maxval=50, group=g_filters)
i_mom_macd_fast = input.int(12, "MACD Fast", minval=5, maxval=50, group=g_filters, inline="macd")
i_mom_macd_slow = input.int(26, "Slow", minval=10, maxval=100, group=g_filters, inline="macd")
i_mom_macd_signal = input.int(9, "Signal", minval=3, maxval=50, group=g_filters, inline="macd")
i_mom_stoch_len = input.int(14, "Stoch Length", minval=5, maxval=50, group=g_filters, inline="stoch")
i_mom_stoch_bull = input.int(20, "Bull <", minval=10, maxval=40, group=g_filters, inline="stoch")
i_mom_stoch_bear = input.int(80, "Bear >", minval=60, maxval=90, group=g_filters, inline="stoch")
i_min_bars = input.int(5, "⏰ Min Bars Between Signals", minval=0, maxval=100, group=g_filters, tooltip=TT_FILTER_TIME)
i_ma1_color_bull = input.color(#00ffcc, "MA1", group=g_visual, inline="c1")
i_ma1_color_bear = input.color(#ff0055, "", group=g_visual, inline="c1")
i_ma1_width = input.int(2, "Width", minval=1, maxval=5, group=g_visual, inline="c1")
i_ma2_color_bull = input.color(#00aaff, "MA2", group=g_visual, inline="c2")
i_ma2_color_bear = input.color(#ff9900, "", group=g_visual, inline="c2")
i_ma2_width = input.int(2, "Width", minval=1, maxval=5, group=g_visual, inline="c2")
i_ma3_color_bull = input.color(#aa00ff, "MA3", group=g_visual, inline="c3")
i_ma3_color_bear = input.color(#ffff00, "", group=g_visual, inline="c3")
i_ma3_width = input.int(2, "Width", minval=1, maxval=5, group=g_visual, inline="c3")
i_use_gradient = input.bool(true, "🎨 Slope Gradient", group=g_visual, inline="fx")
i_glow_effect = input.bool(true, "✨ Glow Effect", group=g_visual, inline="fx")
i_show_signals = input.bool(true, "📍 Show Signal Labels", group=g_visual, inline="sig")
i_signal_size = input.string("Small", "", options=["Tiny", "Small", "Normal"], group=g_visual, inline="sig")
i_perf_enable = input.bool(false, "📊 Enable Performance Tracking", group=g_perf)
i_perf_capital = input.float(10000, "Starting Capital", minval=100, group=g_perf, inline="perf1")
i_perf_pos_size = input.float(10, "Position %", minval=1, maxval=100, group=g_perf, inline="perf1")
i_perf_commission = input.float(0.04, "Commission %", minval=0, maxval=1, step=0.01, group=g_perf, inline="perf2")
i_dash_enable = input.bool(true, "📋 Show Dashboard", group=g_dash, inline="dash")
i_dash_size = input.string("Small", "Size", options=["Small", "Normal", "Large"], group=g_dash, inline="dash")
i_dash_pos = input.string("Top Right", "Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=g_dash, inline="dash2")
