// ═══════════════════════════════════════════════════════════════════════════════
// 📚 TYPE DEFINITIONS
// ═══════════════════════════════════════════════════════════════════════════════
type TradeStats
    int trades = 0
    int wins = 0
    int losses = 0
    float total_pnl = 0.0
    float win_pnl = 0.0
    float loss_pnl = 0.0
    float max_dd = 0.0
    float peak_equity = 0.0
    float current_equity = 0.0
    bool in_trade = false
    int direction = 0
    float entry_price = 0.0
    int entry_bar = 0
type BandZone
    float level = 0.0
    float strength = 0.0
    int bar_idx = 0
    bool is_upper = true
    int touches = 0
    float delta = 0.0
chart_high = ta.highest(high, 200)
chart_low = ta.lowest(low, 200)
chart_range = chart_high - chart_low
// ═══════════════════════════════════════════════════════════════════════════════
// 📐 CORE ARRAYS & VARIABLES
// ═══════════════════════════════════════════════════════════════════════════════
var array<float> upper_zones = array.new<float>()
var array<float> upper_strengths = array.new<float>()
var array<int> upper_bars = array.new<int>()
var array<int> upper_touches = array.new<int>()
var array<float> lower_zones = array.new<float>()
var array<float> lower_strengths = array.new<float>()
var array<int> lower_bars = array.new<int>()
var array<int> lower_touches = array.new<int>()
var array<box> zone_boxes = array.new<box>()
var array<label> zone_labels = array.new<label>()
var array<line> viz_lines = array.new<line>()
var array<label> viz_labels = array.new<label>()
var array<box> viz_boxes = array.new<box>()
var array<float> h1_history = array.new<float>(100, 0.0)
var array<float> h2_history = array.new<float>(100, 0.0)
var array<float> h3_history = array.new<float>(100, 0.0)
var array<float> bandwidth_history = array.new<float>()
var array<float> pctb_history = array.new<float>()
f_cleanupLines(arr, max) =>
    while array.size(arr) > max
        line.delete(array.shift(arr))
f_cleanupLabels(arr, max) =>
    while array.size(arr) > max
        label.delete(array.shift(arr))
f_cleanupBoxes(arr, max) =>
    while array.size(arr) > max
        box.delete(array.shift(arr))
// ═══════════════════════════════════════════════════════════════════════════════
// 📊 BASIS CALCULATION FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════
f_sma(src, len) => ta.sma(src, len)
f_ema(src, len) => ta.ema(src, len)
f_wma(src, len) => ta.wma(src, len)
f_vwma(src, len) => ta.vwma(src, len)
f_hull(src, len) =>
    half_len = math.max(1, int(len / 2))
    sqrt_len = math.max(1, int(math.sqrt(len)))
    ta.wma(2 * ta.wma(src, half_len) - ta.wma(src, len), sqrt_len)
f_kama(src, len) =>
    change_val = math.abs(src - src[len])
    volatility = math.sum(math.abs(src - src[1]), len)
    er = volatility != 0 ? change_val / volatility : 0
    sc = math.pow(er * (2.0/3 - 2.0/31) + 2.0/31, 2)
    var float kama = na
    kama := na(kama) ? src : kama + sc * (src - kama)
f_vidya(src, len) =>
    cmo = ta.cmo(src, len)
    alpha = 2.0 / (len + 1)
    abs_cmo = math.abs(cmo) / 100
    var float vidya = na
    vidya := na(vidya) ? src : alpha * abs_cmo * src + (1 - alpha * abs_cmo) * nz(vidya[1])
f_frama(src, len) =>
    half_len = math.max(1, int(len / 2))
    n3 = (ta.highest(high, len) - ta.lowest(low, len)) / len
    n1 = (ta.highest(high, half_len) - ta.lowest(low, half_len)) / half_len
    n2 =