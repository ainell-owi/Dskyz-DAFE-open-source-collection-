var string TT_BAND = "🎯 BAND TYPE\n\nSelect from 14 band calculation methods:\n• Classic: Bollinger, Keltner, Donchian\n• Statistical: Parkinson, Yang-Zhang\n• DAFE Proprietary: Quantum, Neural, Gravity"
